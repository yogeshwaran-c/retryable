{
  "name": "@yogeshyc/retryable",
  "version": "0.1.0",
  "description": "Async retry with exponential backoff, jitter, and AbortSignal support. Zero dependencies.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run test",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "retry",
    "async",
    "backoff",
    "exponential-backoff",
    "jitter",
    "abort",
    "AbortSignal",
    "promise",
    "typescript",
    "zero-dependency"
  ],
  "author": "yogeshwaran-c",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yogeshwaran-c/retryable.git"
  },
  "homepage": "https://github.com/yogeshwaran-c/retryable#readme",
  "bugs": {
    "url": "https://github.com/yogeshwaran-c/retryable/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
